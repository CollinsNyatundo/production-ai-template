# Application Config
APP_ENV=development
PORT=8000

# Redis Cache Service
REDIS_URL=redis://localhost:6379/0

# LLM Providers (Configure keys for actual use)
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Production Observability (Langfuse / Langsmith Integration)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
