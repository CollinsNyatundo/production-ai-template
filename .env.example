# Application Config
APP_ENV=development
PORT=8000

# REQUIRED outside development. The app refuses to start if APP_ENV is not
# "development"/"test" and this is still the published default - generate a
# real one with: openssl rand -hex 32
JWT_SECRET=production-super-secret-key-change-me

# Database (SQLite by default; switch to a Postgres URL for anything beyond
# local dev - see app/services/database.py for the dialect switch)
DATABASE_URL=sqlite:///app.db

# CORS - comma-separated list of allowed origins. Never widen this to "*"
# while allow_credentials is on (see app/main.py).
CORS_ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000

# Redis Cache Service (reserved - semantic_cache.py is in-process memory today,
# not yet Redis-backed; see app/services/semantic_cache.py)
REDIS_URL=redis://localhost:6379/0

# LLM Provider - NVIDIA NIM (OpenAI-compatible). This is the only provider
# actually wired into the app; see app/services/llm_client.py. Any model in
# the NVIDIA API catalog can be dropped in via NVIDIA_MODEL.
NVIDIA_API_KEY=your-nvidia-api-key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
LLM_REQUEST_TIMEOUT_S=30

# Observability - LangSmith (LLM call tracing + optional Prompt Hub for
# app/prompts/registry.py). Leave LANGSMITH_TRACING_ENABLED=false to run with
# zero LangSmith setup.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=production-ai-template
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_TRACING_ENABLED=false

# Rate limiting (slowapi)
RATE_LIMIT_CALLS=60
RATE_LIMIT_PERIOD=60

# Circuit breaker (app/security/resilience.py)
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT=30
